# Copy to .env.local for local development (values below are dev defaults)
# Copy to .env.production for production builds (use real values)

# URL of the deployed Cloudflare Worker
# Local dev: wrangler dev runs at http://localhost:8787
VITE_WORKER_URL=http://localhost:8787

# HMAC signing salt — MUST match HMAC_SECRET set in the Cloudflare Worker
# Generate a strong random value: openssl rand -hex 32
VITE_LICENSE_SALT=dev-only-salt-change-before-deploy

# Temporary review/demo bypass for deployments where you want to skip Gumroad activation.
# Set to true only for a review build, then remove it afterwards.
VITE_REVIEW_MODE=false
