# Server
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Session TTL in seconds (default 10 minutes — heartbeat every 3min)
SESSION_TTL=600

# SQLite database path
DB_PATH=./data/singularis.db

# CORS — set to your PWA domain in production
ALLOWED_ORIGIN=https://singularis.app

# Gumroad product permalink (for webhook validation)
# Find it at gumroad.com > Products > your product > share
GUMROAD_PERMALINK=singularis
